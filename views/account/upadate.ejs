<%- include("../shared/header") %>
<h1>Update Account</h1>
<form method="post" action="/account/update/<%= account_id %>">
  <label>First Name:</label>
  <input type="text" name="first_name" value="<%= firstName %>" required>
  <label>Last Name:</label>
  <input type="text" name="last_name" value="<%= lastName %>" required>
  <button type="submit">Update</button>
</form>

<h2>Change Password</h2>
<form method="post" action="/account/update-password/<%= account_id %>">
  <label>New Password:</label>
  <input type="password" name="password" required>
  <button type="submit">Change Password</button>
</form>
<%- include("../shared/footer") %>
